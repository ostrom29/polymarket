# ─── Polymarket Wallet ────────────────────────────────────────────────────────
# Your EOA wallet private key on Polygon (0x-prefixed)
# This wallet must hold USDC (Polygon) to place orders
# NEVER commit this file to git
POLYMARKET_PRIVATE_KEY=0x_your_private_key_here

# ─── CLOB API Credentials ─────────────────────────────────────────────────────
# Derived from your wallet via: python3 setup_credentials.py
# These cannot move funds — safe to store, but still keep private
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_PASSPHRASE=

# ─── Execution Mode ───────────────────────────────────────────────────────────
# true  → SHADOW MODE: orders are built + signed but never submitted (safe testing)
# false → LIVE MODE:   orders are submitted to the CLOB (real money)
# Default: true — must explicitly opt into live
SHADOW_MODE=true
